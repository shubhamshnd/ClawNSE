# ─── Nubra API ───────────────────────────────────────────────
NUBRA_BASE_URL=https://api.nubra.io
NUBRA_PHONE=9XXXXXXXXX
NUBRA_MPIN=1234
NUBRA_DEVICE_ID=PIBOT01

# ─── Gemini AI ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─── Scheduler (cron syntax, IST) ────────────────────────────
SCAN_CRON_MARKET_OPEN=0 9 * * 1-5
SCAN_CRON_MID_SESSION=30 11 * * 1-5
SCAN_CRON_AFTERNOON=0 14 * * 1-5
SCAN_CRON_EOD=20 15 * * 1-5

# ─── App ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ─── Strategy defaults ───────────────────────────────────────
DEFAULT_STRATEGY=EMA_CROSSOVER
EMA_SHORT=9
EMA_LONG=21
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD=2
CROSSOVER_PROXIMITY_PERCENT=1.5
